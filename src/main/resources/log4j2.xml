<?xml version="1.0" encoding="UTF-8"?>
<Configuration
	xmlns="http://logging.apache.org/log4j/2.0/config">
	<PatternLayout charset="UTF-8"/>
	<Appenders>
		<Console name="STDOUT" target="SYSTEM_OUT">
			<PatternLayout pattern="%d %t [%-5p] %c{2} - %m%n" />
		</Console>

		<RollingFile name="dailyFileRolling"
			fileName="/opt/apache-tomcat-9.0.111/logs/vijp.log"
			filePattern="/opt/apache-tomcat-9.0.111logs/vijp.log_%d{yyyyMMdd}.log"
			ignoreExceptions="false">
			<PatternLayout>
				<pattern>%d %t [%-5p] %c{2} - %m%n</pattern>
			</PatternLayout>
			<Policies>
				<TimeBasedTriggeringPolicy interval="1" />
			</Policies>
		</RollingFile>
	</Appenders>

	<Loggers>
		<Logger name="eeo.tts" level="debug" />
		<Root level="debug">
			<AppenderRef ref="STDOUT" />
			<AppenderRef ref="dailyFileRolling" />
		</Root>
	</Loggers>

</Configuration>